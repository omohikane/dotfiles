# API keys for LLM services
# Copy this file to api-keys.env and fill in actual values:
#   cp ~/.config/secrets/api-keys.env.sample ~/.config/secrets/api-keys.env
#   chmod 600 ~/.config/secrets/api-keys.env

# === Core LLM providers ===
OPENROUTER_API_KEY=
DEEPSEEK_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# === Useful optional LLM providers ===
XAI_API_KEY=
MISTRAL_API_KEY=
GROQ_API_KEY=
PERPLEXITY_API_KEY=

# === GitHub tooling ===
GH_TOKEN=
GITHUB_TOKEN=
