{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "litellm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LiteLLM",
      "options": {
        "baseURL": "http://127.0.0.1:4000/v1",
        "apiKey": "dummy"
      },
      "models": {
        "cloud-pro": {
          "name": "Cloud Pro (Gemini 2.5 Pro)"
        },
        "cloud-fast": {
          "name": "Cloud Fast (Gemini 2.5 Flash)"
        }
      }
    }
  },
  "agent": {
    "planner": {
      "model": "litellm/cloud-pro"
    },
    "primary": {
      "model": "litellm/cloud-fast"
    }
  }
}
