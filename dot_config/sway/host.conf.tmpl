{{ if eq .machine.type "desktop" }}
# === Display: Desktop ===
output DP-1 {
    mode 2560x1440@59.951Hz
    position 0 1080
}

output DP-3 {
    mode 2560x1440@59.951Hz
    position 2560 0
    transform 270
}

output HDMI-A-1 {
    mode 1920x1080@60Hz
    position 640 0
}

# Workspace assignment
workspace 1 output DP-1
workspace 2 output HDMI-A-1
workspace 3 output DP-3
workspace 4 output DP-1
workspace 5 output DP-1
workspace 6 output DP-3

# Display toggle
bindsym $mod+F1 exec ~/.local/bin/display-toggle.sh single
bindsym $mod+F2 exec ~/.local/bin/display-toggle.sh dual
bindsym $mod+F3 exec ~/.local/bin/display-toggle.sh triple

{{ else if eq .machine.type "laptop" }}
# === Display: Laptop ===
output eDP-1 {
    mode 2560x1600
    scale 1.25
}

workspace 1 output eDP-1

bindsym XF86MonBrightnessUp exec brightnessctl set +5%
bindsym XF86MonBrightnessDown exec brightnessctl set 5%-

{{ end }}
